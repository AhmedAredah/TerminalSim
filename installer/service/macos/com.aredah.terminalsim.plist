<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>            <string>com.aredah.terminalsim</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/terminal_simulation</string>
    </array>
    <key>RunAtLoad</key>        <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key><false/>
        <key>Crashed</key>       <true/>
    </dict>
    <key>StandardOutPath</key>  <string>/usr/local/var/log/terminalsim/stdout.log</string>
    <key>StandardErrorPath</key><string>/usr/local/var/log/terminalsim/stderr.log</string>
    <key>ProcessType</key>      <string>Background</string>
</dict>
</plist>
